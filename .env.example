APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=*
# Render/Railway/Fly will inject PORT automatically at runtime.

CSGT_LOOKUP_URL=https://www.csgt.vn/tra-cuu-phat-nguoi
CSGT_ACTION_PATH=/tra-cuu-vi-pham-qua-hinh-anh
SCRAPER_TIMEOUT_SECONDS=45
SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_USE_PLAYWRIGHT=true
SCRAPER_HEADLESS=true
SCRAPER_ENABLE_CSGT=true

# Secondary fallback. This is a public endpoint used by phatnguoi.vn.
SCRAPER_ENABLE_PHATNGUOI=true
PHATNGUOI_API_URL=https://api.phatnguoi.vn/web/tra-cuu/{plate}/{vehicle_code}
PHATNGUOI_TIMEOUT_SECONDS=30

# Local cache prevents repeated calls that trigger daily limits.
TRAFFIC_FINE_CACHE_PATH=.cache/traffic_fines.json
TRAFFIC_FINE_CACHE_MAX_AGE_HOURS=12

# Optional official HCMC provider. It needs an OCR/captcha service.
SCRAPER_ENABLE_HCMC=false
HCMC_LOOKUP_URL=https://csgt-congan.hochiminhcity.gov.vn/wps/portal/Home/tra-cuu-vi-pham
HCMC_CAPTCHA_URL=https://csgt-congan.hochiminhcity.gov.vn/wps/VPGT/kaptcha.jpg
HCMC_ACTION_URL=https://csgt-congan.hochiminhcity.gov.vn/wps/VPGT/view/getListViPham.do
HCMC_CAPTCHA_SOLVER_URL=

# Only used when SCRAPER_USE_PLAYWRIGHT=false. CSGT currently requires a
# valid reCAPTCHA v3 token from its page flow, so requests mode is mainly for
# controlled tests or if you proxy a legitimate token provider internally.
CSGT_RECAPTCHA_TOKEN=
